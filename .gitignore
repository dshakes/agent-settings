# Local overrides — never commit machine-specific or secret config
*.local.json
*.local.toml
.env
.env.*
*.key
*.pem

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/

# Python / tooling caches (compass-memory reference server)
__pycache__/
*.pyc
.ruff_cache/
venv/
.sdlc/

# Backups created by the installer (these live under ~/.claude anyway)
backups/
