#!/usr/bin/env bash
# compass — one CLI for compass's local tools. Put bin/ on your PATH, or call
# ~/compass/bin/compass directly. Each subcommand is a script in ../scripts.
set -euo pipefail

# Resolve through symlinks (we're installed as ~/.local/bin/compass -> <repo>/bin/compass)
# so the repo root — and scripts/ — is found no matter how compass is invoked.
SRC="${BASH_SOURCE[0]}"
while [ -L "$SRC" ]; do
  dir="$(cd -P "$(dirname "$SRC")" && pwd)"
  SRC="$(readlink "$SRC")"
  case "$SRC" in /*) ;; *) SRC="$dir/$SRC" ;; esac
done
HERE="$(cd -P "$(dirname "$SRC")" && pwd)"
# COMPASS_REPO_ROOT lets a packaged install (e.g. Homebrew) pin the repo root to a
# stable path that survives upgrades. Unset → resolve from our own location (git clone).
ROOT="${COMPASS_REPO_ROOT:-$(dirname "$HERE")}"
SCRIPTS="$ROOT/scripts"

cmd="${1:-help}"; [ "$#" -gt 0 ] && shift

usage() {
  cat <<EOF
compass — local engineering tools

usage: compass <command> [args]

  quickstart [flags]       Install + validate + the 60-second on-ramp (idempotent;
                           re-run to repair). Pass-through: --mcp --gemini --copy --yes.
  status  [DIR]            Is compass enabled here? Global config + this-repo extras.
  onboard [DIR] | --all <glob>
                           Onboard into a repo: detect stack, deps, build+test green,
                           write a grounded CLAUDE.md, print a codebase map. --all does many.
  impact  [--week|--all]   What compass did for you: footguns blocked, files formatted,
                           spend by model, estimated \$ saved vs all-Opus.
  spend   [--week|--month] Agent cost dashboard + budget (set COMPASS_BUDGET_USD).
  schedule add|list|remove|run <routine>
                           Local scheduled agents (cron + claude -p): dep-refresh,
                           flaky-triage, doc-freshness, pr-babysit.
  route   "<task>"         Print the cheapest-correct model tier (experimental).
  notify  "<message>"      DM your phone via lantern's iMessage/WhatsApp bridge
                           (set COMPASS_NOTIFY_URL/_TOKEN; --dry-run to preview).
  listen                   Run the command listener: act on /status /approve /hold /build
                           sent from your iMessage/WhatsApp DM (long-running; needs gh + bridge).
  doctor                   Validate the compass install (make doctor).
  help                     This message.

Ledgers + config live in \${COMPASS_HOME:-~/.compass}. Everything is opt-in.
EOF
}

run() { local s="$SCRIPTS/compass-$1.sh"; shift; [ -x "$s" ] || { echo "compass: missing $s" >&2; exit 1; }; exec "$s" "$@"; }

case "$cmd" in
  quickstart) exec "$ROOT/quickstart.sh" "$@" ;;
  status)   run status "$@" ;;
  onboard)  run onboard "$@" ;;
  impact)   run impact "$@" ;;
  spend)    run spend "$@" ;;
  schedule) run schedule "$@" ;;
  route)    run route "$@" ;;
  notify)   run notify "$@" ;;
  listen)   command -v node >/dev/null || { echo "compass listen: node required" >&2; exit 1; }; exec node "$SCRIPTS/compass-listen.mjs" "$@" ;;
  doctor)   exec make -C "$ROOT" doctor ;;
  -h|--help|help) usage ;;
  *) echo "compass: unknown command '$cmd'" >&2; echo; usage; exit 2 ;;
esac
